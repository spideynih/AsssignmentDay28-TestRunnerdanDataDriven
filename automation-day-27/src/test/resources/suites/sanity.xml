<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Sanity Suite" parallel="methods" thread-count="3" verbose="1">

    <listeners>
        <listener class-name="core.TestListener"/>
    </listeners>

    <parameter name="env" value="staging"/>
    <parameter name="browser" value="chrome"/>

    <!-- Login Test -->
    <test name="Sanity Test Login">
        <classes>
            <class name="saucedemo.LoginTest"/>
        </classes>
    </test>

    <!-- Cart Test -->
    <test name="Sanity Test Cart">
        <classes>
            <class name="saucedemo.AddToCartTest"/>
        </classes>
    </test>

    <!-- Checkout Test -->
    <test name="Sanity Test Checkout">
        <classes>
            <class name="saucedemo.CheckoutTest"/>
        </classes>
    </test>

</suite>